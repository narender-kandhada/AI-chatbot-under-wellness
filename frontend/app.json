{
  "expo": {
    "name": "InnerCircle",
    "slug": "wellness-mrce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_square.png",
    "splash": {
      "image": "./assets/images/icon_square.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.narenderkandhada.innercircle",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      "expo-speech-recognition",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_square.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.narenderkandhada.boltexponativewind"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5cb07228-0198-4cf4-9a1a-441c65b78d1c"
      }
    }
  }
}
